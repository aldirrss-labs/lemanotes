# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service role key (server-side only, JANGAN diawali NEXT_PUBLIC)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Enkripsi token Google Drive (AES-256-GCM) ----
# generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=64-hex-chars-here

# ---- Google OAuth (Google Cloud Console) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gdrive/callback
# produksi: https://notes.lemacore.com/api/gdrive/callback

# ---- Cron secret (proteksi endpoint cron di Vercel) ----
CRON_SECRET=some-random-string

# ---- App URL ----
# dev: http://localhost:3000  |  produksi: https://notes.lemacore.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
